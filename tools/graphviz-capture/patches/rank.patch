+
+static void mbt_write_json_string(FILE *out, const char *s)
+{
+    fputc('"', out);
+    if (!s) {
+        fputc('"', out);
+        return;
+    }
+    for (; *s; s++) {
+        unsigned char ch = (unsigned char)*s;
+        switch (ch) {
+        case '\\':
+            fputs("\\\\", out);
+            break;
+        case '"':
+            fputs("\\\"", out);
+            break;
+        case '\n':
+            fputs("\\n", out);
+            break;
+        case '\r':
+            fputs("\\r", out);
+            break;
+        case '\t':
+            fputs("\\t", out);
+            break;
+        default:
+            if (ch < 0x20)
+                fprintf(out, "\\u%04x", ch);
+            else
+                fputc(ch, out);
+        }
+    }
+    fputc('"', out);
+}
+
+static void mbt_write_json_string_or_null(FILE *out, const char *s)
+{
+    if (s)
+        mbt_write_json_string(out, s);
+    else
+        fputs("null", out);
+}
+
+static const char *mbt_rank_node_kind(node_t *n)
+{
+    switch (ND_node_type(n)) {
+    case NORMAL:
+        return "normal";
+    case VIRTUAL:
+        return "virtual";
+    case SLACKNODE:
+        return "slack";
+    case REVERSED:
+        return "reversed";
+    case FLATORDER:
+        return "flatorder";
+    case CLUSTER_EDGE:
+        return "cluster";
+    case IGNORED:
+        return "ignored";
+    default:
+        return "unknown";
+    }
+}
+
+static int mbt_rank_node_id(node_t *n, node_t **nodes, size_t count)
+{
+    for (size_t i = 0; i < count; i++) {
+        if (nodes[i] == n)
+            return (int)i;
+    }
+    return -1;
+}
+
+static int mbt_rank_edge_id(edge_t *edge, node_t **nodes, size_t count)
+{
+    int idx = 0;
+    for (size_t i = 0; i < count; i++) {
+        edge_t *e;
+        for (int j = 0; (e = ND_out(nodes[i]).list[j]); j++) {
+            if (e == edge)
+                return idx;
+            idx++;
+        }
+    }
+    return -1;
+}
+
+static mbt_rank_capture_t mbt_rank_capture_input(graph_t *g, int balance)
+{
+    mbt_rank_capture_t cap = {0};
+    FILE *out = mbt_rank_log_open();
+    if (!out)
+        return cap;
+
+    cap.case_id = ++mbt_rank_case_id;
+
+    size_t count = 0;
+    for (node_t *n = GD_nlist(g); n; n = ND_next(n))
+        count++;
+    cap.node_count = count;
+    cap.nodes = gv_calloc(count, sizeof(node_t *));
+
+    size_t idx = 0;
+    for (node_t *n = GD_nlist(g); n; n = ND_next(n))
+        cap.nodes[idx++] = n;
+
+    fprintf(out,
+            "{\"event\":\"simplex_input\",\"case\":%d,\"balance\":%d,\"nodes\":[",
+            cap.case_id, balance);
+    for (size_t i = 0; i < cap.node_count; i++) {
+        if (i > 0)
+            fputc(',', out);
+        node_t *n = cap.nodes[i];
+        const char *name = (ND_node_type(n) == NORMAL) ? agnameof(n) : NULL;
+        fprintf(out, "{\"id\":%d,\"name\":", (int)i);
+        mbt_write_json_string_or_null(out, name);
+        fputs(",\"kind\":", out);
+        mbt_write_json_string(out, mbt_rank_node_kind(n));
+        fprintf(out, ",\"rank\":%d}", ND_rank(n));
+    }
+    fputs("],\"edges\":[", out);
+    bool first_edge = true;
+    for (size_t i = 0; i < cap.node_count; i++) {
+        node_t *tail = cap.nodes[i];
+        edge_t *e;
+        for (int j = 0; (e = ND_out(tail).list[j]); j++) {
+            int head_id = mbt_rank_node_id(aghead(e), cap.nodes, cap.node_count);
+            if (head_id < 0)
+                continue;
+            if (!first_edge)
+                fputc(',', out);
+            first_edge = false;
+            int in_pos = -1;
+            edge_t *in_edge;
+            for (int k = 0; (in_edge = ND_in(aghead(e)).list[k]); k++) {
+                if (in_edge == e) {
+                    in_pos = k;
+                    break;
+                }
+            }
+            fprintf(out,
+                    "{\"tail\":%d,\"head\":%d,\"minlen\":%d,\"weight\":%d,\"seq\":%llu,\"in_pos\":%d}",
+                    (int)i, head_id, ED_minlen(e), ED_weight(e),
+                    (unsigned long long)AGSEQ(e), in_pos);
+        }
+    }
+    fputs("]}\n", out);
+    fflush(out);
+
+    return cap;
+}
+
+static void mbt_rank_capture_ranks(
+    const mbt_rank_capture_t *cap,
