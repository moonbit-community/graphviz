+static FILE *mbt_rank_log_open(void)
+{
+    const char *path = getenv("MBT_CAPTURE_RANK");
+    if (!path || !*path)
+        return NULL;
+    if (!mbt_rank_log)
+        mbt_rank_log = fopen(path, "a");
+    return mbt_rank_log;
