+    FILE *out = mbt_rank_log_open();
+    if (!out)
+        return;
+    fprintf(out, "{\"event\":\"%s\",\"case\":%d,\"ranks\":[",
+            event, cap->case_id);
+    for (size_t i = 0; i < cap->node_count; i++) {
+        if (i > 0)
+            fputc(',', out);
+        fprintf(out, "%d", ND_rank(cap->nodes[i]));
+    }
+    fputs("]}\n", out);
+    fflush(out);
+}
+
+static void mbt_rank_capture_pre_balance(const mbt_rank_capture_t *cap)
+{
+    mbt_rank_capture_ranks(cap, "simplex_pre_balance");
+}
+
+static void mbt_rank_capture_output(const mbt_rank_capture_t *cap)
+{
+    mbt_rank_capture_ranks(cap, "simplex_output");
+}
+
+static void mbt_rank_capture_free(mbt_rank_capture_t *cap)
+{
+    if (!cap)
+        return;
+    free(cap->nodes);
+    cap->nodes = NULL;
+    cap->node_count = 0;
+    cap->case_id = 0;
+}
