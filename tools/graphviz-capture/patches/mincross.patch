+static bool matrix_get(adjmatrix_t *me, size_t row, size_t col);
+
+typedef struct {
+    int case_id;
+    size_t node_count;
+    node_t **nodes;
+} mbt_mincross_capture_t;
+
+static FILE *mbt_mincross_log = NULL;
+static int mbt_mincross_case_id = 0;
+static mbt_mincross_capture_t *mbt_mincross_active = NULL;
+static int mbt_mincross_active_pass = 0;
+static int mbt_mincross_active_iter = 0;
+
+static FILE *mbt_mincross_log_open(void)
+{
+    const char *path = getenv("MBT_CAPTURE_MINCROSS");
+    if (!path || !*path)
+        return NULL;
+    if (!mbt_mincross_log)
+        mbt_mincross_log = fopen(path, "a");
+    return mbt_mincross_log;
+}
+
+static void mbt_write_json_string(FILE *out, const char *s)
+{
+    fputc('"', out);
+    if (!s) {
+        fputc('"', out);
+        return;
+    }
+    for (; *s; s++) {
+        unsigned char ch = (unsigned char)*s;
+        switch (ch) {
+        case '\\':
+            fputs("\\\\", out);
+            break;
+        case '"':
+            fputs("\\\"", out);
+            break;
+        case '\n':
+            fputs("\\n", out);
+            break;
+        case '\r':
+            fputs("\\r", out);
+            break;
+        case '\t':
+            fputs("\\t", out);
+            break;
+        default:
+            if (ch < 0x20)
+                fprintf(out, "\\u%04x", ch);
+            else
+                fputc(ch, out);
+        }
+    }
+    fputc('"', out);
+}
+
+static void mbt_write_json_string_or_null(FILE *out, const char *s)
+{
+    if (s)
+        mbt_write_json_string(out, s);
+    else
+        fputs("null", out);
+}
+
+static const char *mbt_mincross_node_kind(node_t *n)
+{
+    switch (ND_node_type(n)) {
+    case NORMAL:
+        return "normal";
+    case VIRTUAL:
+        return "virtual";
+    case SLACKNODE:
+        return "slack";
+    case REVERSED:
+        return "reversed";
+    case FLATORDER:
+        return "flatorder";
+    case CLUSTER_EDGE:
+        return "cluster";
+    case IGNORED:
+        return "ignored";
+    default:
+        return "unknown";
+    }
+}
+
+static const char *mbt_mincross_edge_kind(edge_t *e)
+{
+    switch (ED_edge_type(e)) {
+    case NORMAL:
+        return "normal";
+    case VIRTUAL:
+        return "virtual";
+    case SLACKNODE:
+        return "slack";
+    case REVERSED:
+        return "reversed";
+    case FLATORDER:
+        return "flatorder";
+    case CLUSTER_EDGE:
+        return "cluster";
+    case IGNORED:
+        return "ignored";
+    default:
+        return "unknown";
+    }
+}
+
+static int mbt_mincross_node_id(node_t *n, node_t **nodes, size_t count)
+{
+    for (size_t i = 0; i < count; i++) {
+        if (nodes[i] == n)
+            return (int)i;
+    }
+    return -1;
+}
+
+static void mbt_mincross_capture_input(
+    graph_t *g,
+    int startpass,
+    mbt_mincross_capture_t *cap)
+{
+    if (!cap || cap->case_id != 0)
+        return;
+    FILE *out = mbt_mincross_log_open();
+    if (!out)
+        return;
+
+    cap->case_id = ++mbt_mincross_case_id;

+    size_t count = 0;
+    for (node_t *n = GD_nlist(g); n; n = ND_next(n))
+        count++;
+    cap->node_count = count;
+    cap->nodes = gv_calloc(count, sizeof(node_t *));
+
+    size_t idx = 0;
+    for (node_t *n = GD_nlist(g); n; n = ND_next(n))
+        cap->nodes[idx++] = n;
+
+    fprintf(out,
+            "{\"event\":\"mincross_input\",\"case\":%d,\"graph\":",
+            cap->case_id);
+    mbt_write_json_string(out, agnameof(g));
+    fprintf(out, ",\"startpass\":%d,\"minrank\":%d,\"maxrank\":%d",
+            startpass, GD_minrank(g), GD_maxrank(g));
+    fprintf(out, ",\"flip\":%s", GD_flip(g) ? "true" : "false");
+    fprintf(out, ",\"nodes\":[");
+    for (size_t i = 0; i < cap->node_count; i++) {
+        if (i > 0)
+            fputc(',', out);
+        node_t *n = cap->nodes[i];
+        const char *name = (ND_node_type(n) == NORMAL) ? agnameof(n) : NULL;
+        fprintf(out, "{\"id\":%d,\"name\":", (int)i);
+        mbt_write_json_string_or_null(out, name);
+        fputs(",\"kind\":", out);
+        mbt_write_json_string(out, mbt_mincross_node_kind(n));
+        fputs(",\"cluster\":", out);
+        if (ND_clust(n))
+            mbt_write_json_string(out, agnameof(ND_clust(n)));
+        else
+            fputs("null", out);
+        fprintf(out, ",\"cluster_skeleton\":%s",
+                (ND_ranktype(n) == CLUSTER && ND_node_type(n) == VIRTUAL) ?
+                "true" : "false");
+        fprintf(out, ",\"rank\":%d,\"order\":%d}",
+                ND_rank(n), ND_order(n));
+    }
+    fputs("],\"edges\":[", out);
+    bool first_edge = true;
+    for (size_t i = 0; i < cap->node_count; i++) {
+        node_t *tail = cap->nodes[i];
+        edge_t *e;
+        for (int j = 0; (e = ND_out(tail).list[j]); j++) {
+            int head_id = mbt_mincross_node_id(aghead(e), cap->nodes, cap->node_count);
+            if (head_id < 0)
+                continue;
+            if (!first_edge)
+                fputc(',', out);
+            first_edge = false;
+            fprintf(out,
+                    "{\"tail\":%d,\"head\":%d,\"minlen\":%d,"
+                    "\"weight\":%d,\"xpenalty\":%d,"
+                    "\"tail_port_x\":%.17g,\"head_port_x\":%.17g,"
+                    "\"tail_port_order\":%u,\"head_port_order\":%u,"
+                    "\"type\":",
+                    (int)i, head_id, ED_minlen(e),
+                    ED_weight(e), ED_xpenalty(e),
+                    ED_tail_port(e).p.x, ED_head_port(e).p.x,
+                    (unsigned int)ED_tail_port(e).order,
+                    (unsigned int)ED_head_port(e).order);
+            mbt_write_json_string(out, mbt_mincross_edge_kind(e));
+            fputc('}', out);
+        }
+    }
+    fputs("],\"flat_edges\":[", out);
+    bool first_flat = true;
+    for (int r = GD_minrank(g); r <= GD_maxrank(g); r++) {
+        adjmatrix_t *M = GD_rank(g)[r].flat;
+        if (!M)
+            continue;
+        for (int i = 0; i < GD_rank(g)[r].n; i++) {
+            node_t *tail = GD_rank(g)[r].v[i];
+            if (!tail)
+                continue;
+            int tail_id = mbt_mincross_node_id(tail, cap->nodes, cap->node_count);
+            if (tail_id < 0)
+                continue;
+            for (int j = 0; j < GD_rank(g)[r].n; j++) {
+                if (i == j)
+                    continue;
+                if (!matrix_get(M, (size_t)i, (size_t)j))
+                    continue;
+                node_t *head = GD_rank(g)[r].v[j];
+                if (!head)
+                    continue;
+                int head_id = mbt_mincross_node_id(head, cap->nodes, cap->node_count);
+                if (head_id < 0)
+                    continue;
+                if (!first_flat)
+                    fputc(',', out);
+                first_flat = false;
+                fprintf(out, "{\"tail\":%d,\"head\":%d}", tail_id, head_id);
+            }
+        }
+    }
+    fputs("],\"ranks\":[", out);
+    for (int r = GD_minrank(g); r <= GD_maxrank(g); r++) {
+        if (r > GD_minrank(g))
+            fputc(',', out);
+        fputc('[', out);
+        int out_idx = 0;
+        for (int i = 0; i < GD_rank(g)[r].n; i++) {
+            node_t *n = GD_rank(g)[r].v[i];
+            if (!n)
+                continue;
+            int id = mbt_mincross_node_id(n, cap->nodes, cap->node_count);
+            if (id < 0)
+                continue;
+            if (out_idx++ > 0)
+                fputc(',', out);
+            fprintf(out, "%d", id);
+        }
+        fputc(']', out);
+    }
+    fputs("]}\n", out);
+    mbt_mincross_active = cap;
+    fflush(out);
+}
+
+static void mbt_mincross_capture_rank_state(
+    graph_t *g,
+    int rank,
+    const char *phase)
+{
+    mbt_mincross_capture_t *cap = mbt_mincross_active;
+    if (!cap || cap->case_id == 0)
+        return;
+    FILE *out = mbt_mincross_log_open();
+    if (!out)
+        return;
+    fprintf(out,
+            "{\"event\":\"mincross_rank\",\"case\":%d,\"pass\":%d,\"iter\":%d,"
+            "\"phase\":",
+            cap->case_id, mbt_mincross_active_pass, mbt_mincross_active_iter);
+    mbt_write_json_string(out, phase);
+    fprintf(out, ",\"rank\":%d,\"order\":[", rank);
+    int out_idx = 0;
+    for (int i = 0; i < GD_rank(g)[rank].n; i++) {
+        node_t *n = GD_rank(g)[rank].v[i];
+        if (!n)
+            continue;
+        int id = mbt_mincross_node_id(n, cap->nodes, cap->node_count);
+        if (id < 0)
+            continue;
+        if (out_idx++ > 0)
+            fputc(',', out);
+        fprintf(out, "%d", id);
+    }
+    fputs("],\"mval\":[", out);
+    out_idx = 0;
+    for (int i = 0; i < GD_rank(g)[rank].n; i++) {
+        node_t *n = GD_rank(g)[rank].v[i];
+        if (!n)
+            continue;
+        if (out_idx++ > 0)
+            fputc(',', out);
+        fprintf(out, "%.17g", ND_mval(n));
+    }
+    fputs("]}\n", out);
+    fflush(out);
+}
+
+static void mbt_mincross_capture_iter_state(
+    graph_t *g,
+    const char *phase)
+{
+    mbt_mincross_capture_t *cap = mbt_mincross_active;
+    if (!cap || cap->case_id == 0)
+        return;
+    FILE *out = mbt_mincross_log_open();
+    if (!out)
+        return;
+    fprintf(out,
+            "{\"event\":\"mincross_iter\",\"case\":%d,\"pass\":%d,\"iter\":%d,"
+            "\"phase\":",
+            cap->case_id, mbt_mincross_active_pass, mbt_mincross_active_iter);
+    mbt_write_json_string(out, phase);
+    fputs(",\"ranks\":[", out);
+    for (int r = GD_minrank(g); r <= GD_maxrank(g); r++) {
+        if (r > GD_minrank(g))
+            fputc(',', out);
+        fputc('[', out);
+        int out_idx = 0;
+        for (int i = 0; i < GD_rank(g)[r].n; i++) {
+            node_t *n = GD_rank(g)[r].v[i];
+            if (!n)
+                continue;
+            int id = mbt_mincross_node_id(n, cap->nodes, cap->node_count);
+            if (id < 0)
+                continue;
+            if (out_idx++ > 0)
+                fputc(',', out);
+            fprintf(out, "%d", id);
+        }
+        fputc(']', out);
+    }
+    fputs("]}\n", out);
+    fflush(out);
+}
+
+static void mbt_mincross_capture_output(
+    graph_t *g,
+    const mbt_mincross_capture_t *cap)
+{
+    if (!cap || cap->case_id == 0)
+        return;
+    FILE *out = mbt_mincross_log_open();
+    if (!out)
+        return;
+    fprintf(out, "{\"event\":\"mincross_output\",\"case\":%d,\"ranks\":[",
+            cap->case_id);
+    for (int r = GD_minrank(g); r <= GD_maxrank(g); r++) {
+        if (r > GD_minrank(g))
+            fputc(',', out);
+        fputc('[', out);
+        int out_idx = 0;
+        for (int i = 0; i < GD_rank(g)[r].n; i++) {
+            node_t *n = GD_rank(g)[r].v[i];
+            if (!n)
+                continue;
+            int id = mbt_mincross_node_id(n, cap->nodes, cap->node_count);
+            if (id < 0)
+                continue;
+            if (out_idx++ > 0)
+                fputc(',', out);
+            fprintf(out, "%d", id);
+        }
+        fputc(']', out);
+    }
+    fputs("]}\n", out);
+    fflush(out);
+}
+
+static void mbt_mincross_capture_free(mbt_mincross_capture_t *cap)
+{
+    if (!cap)
+        return;
+    if (mbt_mincross_active == cap)
+        mbt_mincross_active = NULL;
+    free(cap->nodes);
+    cap->nodes = NULL;
+    cap->node_count = 0;
+    cap->case_id = 0;
+}
