+static FILE *mbt_port_label_log = NULL;
+
+static FILE *mbt_port_label_log_open(void) {
+    const char *path = getenv("MBT_CAPTURE_PORT_LABEL_POS");
+    if (!path || !*path)
+        return NULL;
+    if (!mbt_port_label_log)
+        mbt_port_label_log = fopen(path, "a");
+    return mbt_port_label_log;
+}
+
+static void mbt_write_json_string(FILE *out, const char *s) {
+    fputc('"', out);
+    if (!s) {
+        fputc('"', out);
+        return;
+    }
+    for (; *s; s++) {
+        unsigned char ch = (unsigned char)*s;
+        switch (ch) {
+        case '\\':
+            fputs("\\\\", out);
+            break;
+        case '"':
+            fputs("\\\"", out);
+            break;
+        case '\n':
+            fputs("\\n", out);
+            break;
+        case '\r':
+            fputs("\\r", out);
+            break;
+        case '\t':
+            fputs("\\t", out);
+            break;
+        default:
+            if (ch < 0x20)
+                fprintf(out, "\\u%04x", ch);
+            else
+                fputc(ch, out);
+        }
+    }
+    fputc('"', out);
+}
+
+static void mbt_log_port_label(edge_t *e, bool head_p, pointf pe, pointf pf,
+                               double labelangle, double labeldistance,
+                               double dist) {
+    FILE *out = mbt_port_label_log_open();
+    if (!out || !e)
+        return;
+    textlabel_t *label = head_p ? ED_head_label(e) : ED_tail_label(e);
+    if (!label)
+        return;
+    fprintf(out, "{\"event\":\"port_label_pos\",\"graph\":");
+    mbt_write_json_string(out, agnameof(agroot(agraphof(agtail(e)))));
+    fputs(",\"tail\":", out);
+    mbt_write_json_string(out, agnameof(agtail(e)));
+    fputs(",\"head\":", out);
+    mbt_write_json_string(out, agnameof(aghead(e)));
+    fprintf(out, ",\"head_label\":%s", head_p ? "true" : "false");
+    fputs(",\"label\":", out);
+    mbt_write_json_string(out, label->text ? label->text : "");
+    fprintf(out, ",\"label_html\":%s", label->html ? "true" : "false");
+    fprintf(out, ",\"labelangle\":%.17g", labelangle);
+    fprintf(out, ",\"labeldistance\":%.17g", labeldistance);
+    fprintf(out, ",\"dist\":%.17g", dist);
+    fprintf(out, ",\"pe_x\":%.17g,\"pe_y\":%.17g", pe.x, pe.y);
+    fprintf(out, ",\"pf_x\":%.17g,\"pf_y\":%.17g", pf.x, pf.y);
+    fprintf(out, ",\"pos_x\":%.17g,\"pos_y\":%.17g}\n",
+            label->pos.x, label->pos.y);
+    fflush(out);
+}
+
