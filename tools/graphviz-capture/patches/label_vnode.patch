 #include <dotgen/dot.h>
 #include <stdbool.h>
 #include <stdlib.h>
+#include <stdio.h>
 #include <util/alloc.h>
 #include <util/gv_math.h>
 
+static FILE *mbt_label_vnode_log = NULL;
+
+static FILE *mbt_label_vnode_log_open(void)
+{
+    const char *path = getenv("MBT_CAPTURE_LABEL_VNODES");
+    if (!path || !*path)
+        return NULL;
+    if (!mbt_label_vnode_log)
+        mbt_label_vnode_log = fopen(path, "a");
+    return mbt_label_vnode_log;
+}
+
+static void mbt_write_json_string(FILE *out, const char *s)
+{
+    fputc('"', out);
+    if (!s) {
+        fputc('"', out);
+        return;
+    }
+    for (; *s; s++) {
+        unsigned char ch = (unsigned char)*s;
+        switch (ch) {
+        case '\\':
+            fputs("\\\\", out);
+            break;
+        case '"':
+            fputs("\\\"", out);
+            break;
+        case '\n':
+            fputs("\\n", out);
+            break;
+        case '\r':
+            fputs("\\r", out);
+            break;
+        case '\t':
+            fputs("\\t", out);
+            break;
+        default:
+            if (ch < 0x20)
+                fprintf(out, "\\u%04x", ch);
+            else
+                fputc(ch, out);
+        }
+    }
+    fputc('"', out);
+}
+
+static void mbt_log_label_vnode(
+    graph_t *g, edge_t *orig, node_t *v,
+    int rank, int label_rank, int tail_rank, int head_rank)
+{
+    FILE *out = mbt_label_vnode_log_open();
+    if (!out || !orig || !v || !ED_label(orig))
+        return;
+    textlabel_t *label = ED_label(orig);
+    fprintf(out, "{\"event\":\"label_vnode\",\"graph\":");
+    mbt_write_json_string(out, agnameof(agroot(g)));
+    fputs(",\"tail\":", out);
+    mbt_write_json_string(out, agnameof(agtail(orig)));
+    fputs(",\"head\":", out);
+    mbt_write_json_string(out, agnameof(aghead(orig)));
+    fputs(",\"label\":", out);
+    mbt_write_json_string(out, label->text ? label->text : "");
+    fprintf(out, ",\"label_html\":%s", label->html ? "true" : "false");
+    fprintf(out, ",\"label_ontop\":%s", ED_label_ontop(orig) ? "true" : "false");
+    fprintf(out, ",\"flip\":%s", GD_flip(agroot(g)) ? "true" : "false");
+    fprintf(out, ",\"nodesep\":%.17g", (double)GD_nodesep(agroot(g)));
+    fprintf(out, ",\"tail_rank\":%d,\"head_rank\":%d", tail_rank, head_rank);
+    fprintf(out, ",\"label_rank\":%d,\"rank\":%d", label_rank, rank);
+    fprintf(out, ",\"dimen_x\":%.17g,\"dimen_y\":%.17g",
+            label->dimen.x, label->dimen.y);
+    fprintf(out, ",\"lw\":%.17g,\"rw\":%.17g,\"ht\":%.17g}\n",
+            ND_lw(v), ND_rw(v), ND_ht(v));
+    fflush(out);
+}
