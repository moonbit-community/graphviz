+static FILE *mbt_edge_label_pos_log = NULL;
+
+static FILE *mbt_edge_label_pos_log_open(void) {
+  const char *path = getenv("MBT_CAPTURE_EDGE_LABEL_POS");
+  if (!path || !*path)
+    return NULL;
+  if (!mbt_edge_label_pos_log)
+    mbt_edge_label_pos_log = fopen(path, "a");
+  return mbt_edge_label_pos_log;
+}
+
+static void mbt_write_json_string(FILE *out, const char *s) {
+  fputc('"', out);
+  if (!s) {
+    fputc('"', out);
+    return;
+  }
+  for (; *s; s++) {
+    unsigned char ch = (unsigned char)*s;
+    switch (ch) {
+    case '\\':
+      fputs("\\\\", out);
+      break;
+    case '"':
+      fputs("\\\"", out);
+      break;
+    case '\n':
+      fputs("\\n", out);
+      break;
+    case '\r':
+      fputs("\\r", out);
+      break;
+    case '\t':
+      fputs("\\t", out);
+      break;
+    default:
+      if (ch < 0x20)
+        fprintf(out, "\\u%04x", ch);
+      else
+        fputc(ch, out);
+    }
+  }
+  fputc('"', out);
+}
+
+static void mbt_log_edge_label_vnode(graph_t *g, edge_t *e, node_t *n) {
+  FILE *out = mbt_edge_label_pos_log_open();
+  if (!out || !e || !n || !ED_label(e))
+    return;
+  textlabel_t *label = ED_label(e);
+  fprintf(out, "{\"event\":\"edge_label_vnode\",\"graph\":");
+  mbt_write_json_string(out, agnameof(agroot(g)));
+  fputs(",\"tail\":", out);
+  mbt_write_json_string(out, agnameof(agtail(e)));
+  fputs(",\"head\":", out);
+  mbt_write_json_string(out, agnameof(aghead(e)));
+  fputs(",\"label\":", out);
+  mbt_write_json_string(out, label->text ? label->text : "");
+  fprintf(out, ",\"label_html\":%s", label->html ? "true" : "false");
+  fprintf(out, ",\"flip\":%s", GD_flip(agroot(g)) ? "true" : "false");
+  fprintf(out, ",\"vnode_x\":%.17g,\"vnode_y\":%.17g",
+          ND_coord(n).x, ND_coord(n).y);
+  fprintf(out, ",\"dimen_x\":%.17g,\"dimen_y\":%.17g",
+          label->dimen.x, label->dimen.y);
+  fprintf(out, ",\"pos_x\":%.17g,\"pos_y\":%.17g}\n",
+          label->pos.x, label->pos.y);
+  fflush(out);
+}
+
+static void mbt_log_edge_label_flat(graph_t *g, edge_t *e, pointf tp,
+                                    pointf hp, double tail_rw,
+                                    double head_lw, unsigned place) {
+  FILE *out = mbt_edge_label_pos_log_open();
+  if (!out || !e || !ED_label(e))
+    return;
+  textlabel_t *label = ED_label(e);
+  fprintf(out, "{\"event\":\"edge_label_flat\",\"graph\":");
+  mbt_write_json_string(out, agnameof(agroot(g)));
+  fputs(",\"tail\":", out);
+  mbt_write_json_string(out, agnameof(agtail(e)));
+  fputs(",\"head\":", out);
+  mbt_write_json_string(out, agnameof(aghead(e)));
+  fputs(",\"label\":", out);
+  mbt_write_json_string(out, label->text ? label->text : "");
+  fprintf(out, ",\"label_html\":%s", label->html ? "true" : "false");
+  fprintf(out, ",\"flip\":%s", GD_flip(agroot(g)) ? "true" : "false");
+  fprintf(out, ",\"tp_x\":%.17g,\"tp_y\":%.17g", tp.x, tp.y);
+  fprintf(out, ",\"hp_x\":%.17g,\"hp_y\":%.17g", hp.x, hp.y);
+  fprintf(out, ",\"tail_rw\":%.17g,\"head_lw\":%.17g", tail_rw, head_lw);
+  fprintf(out, ",\"place\":%u", place);
+  fprintf(out, ",\"dimen_x\":%.17g,\"dimen_y\":%.17g",
+          label->dimen.x, label->dimen.y);
+  fprintf(out, ",\"pos_x\":%.17g,\"pos_y\":%.17g}\n",
+          label->pos.x, label->pos.y);
+  fflush(out);
+}
