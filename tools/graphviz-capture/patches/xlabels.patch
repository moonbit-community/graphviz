+static size_t mbt_xlabel_count = 0;
+
+static FILE *mbt_xlabel_log_open(void) {
+    const char *path = getenv("MBT_CAPTURE_XLABELS");
+    if (!path || !*path)
+        return NULL;
+    if (!mbt_xlabel_log)
+        mbt_xlabel_log = fopen(path, "a");
+    return mbt_xlabel_log;
+}
+
+static void mbt_clear_xlabel_capture(void) {
+    if (mbt_xlabel_labels) {
+        free(mbt_xlabel_labels);
+        mbt_xlabel_labels = NULL;
+    }
+    if (mbt_xlabel_meta_data) {
+        free(mbt_xlabel_meta_data);
+        mbt_xlabel_meta_data = NULL;
+    }
+    mbt_xlabel_count = 0;
+}
+
+static void mbt_write_json_string(FILE *out, const char *s) {
+    fputc('"', out);
+    if (!s) {
+        fputc('"', out);
+        return;
+    }
+    for (; *s; s++) {
+        unsigned char ch = (unsigned char)*s;
+        switch (ch) {
+        case '\\':
+            fputs("\\\\", out);
+            break;
+        case '"':
+            fputs("\\\"", out);
+            break;
+        case '\n':
+            fputs("\\n", out);
+            break;
+        case '\r':
+            fputs("\\r", out);
+            break;
+        case '\t':
+            fputs("\\t", out);
+            break;
+        default:
+            if (ch < 0x20)
+                fprintf(out, "\\u%04x", ch);
+            else
+                fputc(ch, out);
+        }
+    }
+    fputc('"', out);
+}
+
+static void mbt_log_xlabel(graph_t *g, const textlabel_t *label,
+                           const mbt_xlabel_meta *meta) {
+    FILE *out = mbt_xlabel_log_open();
+    if (!out || !label || !meta || !meta->kind)
+        return;
+    fprintf(out, "{\"event\":\"xlabel\",\"graph\":");
+    mbt_write_json_string(out, agnameof(agroot(g)));
+    fputs(",\"kind\":", out);
+    mbt_write_json_string(out, meta->kind);
+    fputs(",\"node\":", out);
+    mbt_write_json_string(out, meta->node ? meta->node : "");
+    fputs(",\"tail\":", out);
+    mbt_write_json_string(out, meta->tail ? meta->tail : "");
+    fputs(",\"head\":", out);
+    mbt_write_json_string(out, meta->head ? meta->head : "");
+    fputs(",\"label\":", out);
+    mbt_write_json_string(out, label->text ? label->text : "");
+    fprintf(out, ",\"label_html\":%s", label->html ? "true" : "false");
+    fprintf(out, ",\"flip\":%s", GD_flip(agroot(g)) ? "true" : "false");
+    fprintf(out, ",\"width\":%.17g,\"height\":%.17g",
+            label->dimen.x, label->dimen.y);
+    fprintf(out, ",\"pos_x\":%.17g,\"pos_y\":%.17g}\n",
+            label->pos.x, label->pos.y);
+    fflush(out);
+}
+
+static void mbt_log_xlabels_after_translate(graph_t *g) {
+    if (!mbt_xlabel_labels || !mbt_xlabel_meta_data || mbt_xlabel_count == 0)
+        return;
+    for (size_t i = 0; i < mbt_xlabel_count; i++) {
+        textlabel_t *label = mbt_xlabel_labels[i];
+        const mbt_xlabel_meta *meta = &mbt_xlabel_meta_data[i];
+        if (!label || !label->set || !meta->kind)
+            continue;
+        mbt_log_xlabel(g, label, meta);
+    }
+    mbt_clear_xlabel_capture();
+}
