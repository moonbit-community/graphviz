    { x: 122.0, y: 224.0 },
    { x: 252.0, y: 224.0 },
    { x: 252.0, y: 188.0 },
    { x: 122.0, y: 188.0 },
    { x: 122.0, y: 152.0 },
    { x: 252.0, y: 152.0 },
    { x: 252.0, y: 116.0 },
    { x: 122.0, y: 116.0 },
    { x: 122.0, y: 80.0 },
    { x: 252.0, y: 80.0 },
    { x: 252.0, y: 44.0 },
    { x: 122.0, y: 44.0 },
    { x: 122.0, y: 26.0 },
    { x: -80.0, y: 26.0 },
    { x: -80.0, y: 44.0 },
