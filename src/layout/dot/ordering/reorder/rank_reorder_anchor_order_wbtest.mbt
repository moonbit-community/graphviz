        cluster_skeleton: false,
        out_neighbors: [],
        in_neighbors: [],
        out_all_neighbors: ["fmt_tif"],
        in_all_neighbors: [],
      },
      {
        id: 5,
        name: Some("tiff"),
        rank: 0,
        order: 5,
        cluster: None,
        cluster_skeleton: false,
        out_neighbors: [],
