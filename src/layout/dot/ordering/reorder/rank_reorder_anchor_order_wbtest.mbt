///|
test "rank_reorder aligns plugin cluster-core routers and outputs to external anchor order" {
  let (input, output, name_order) = plugin_cluster_core_anchor_order_case()
  run_mincross_case_with_name_order(input, output, name_order)
}

///|
/// Graphviz parity: the remaining plugin replay signal comes from the full
/// integrated plugin graph where every rank participates in the anchor-order
/// closure. Keep this owner-local direct case explicit so the plugin fixture
/// replay can be fully retired without hiding the dense cross-rank structure
/// behind fixture I/O. Preserve the captured node and edge array order
/// verbatim because `run_mincross_case_with_name_order` uses that capture
/// order as the local fallback ordering baseline.
