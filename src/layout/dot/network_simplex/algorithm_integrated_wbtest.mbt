    { name: "handle_1", kind: NodeKind::Normal, rank: 890 },
    { name: "handle_x", kind: NodeKind::Normal, rank: 995 },
    { name: "other_xprot", kind: NodeKind::Normal, rank: 474 },
    { name: "", kind: NodeKind::Virtual, rank: 48 },
