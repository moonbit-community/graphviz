    pre_balance_ranks_for_test(balance_graph),
    [1, 2, 3, 0, 1, 1, 2, 3, 3, 4, 5, 6, 5, 5, 6, 3, 2, 2, 3, 3, 4, 5, 6, 5, 5, 6, 4, 4, 5, 6, 6, 7, 8, 9, 8, 8, 9, 6, 3, 1, 1, 2, 3],
